# Google Gemini API (Opsional - Sebagai Fallback)
# GOOGLE_GENERATIVE_AI_API_KEY=your_gemini_api_key

# EdgeTTS Local Server (Dibutuhkan untuk suara karakter)
# Jalankan edge-tts-server/start.bat terlebih dahulu
TTS_EDGE_BASE_URL="http://localhost:5050"
TTS_EDGE_API_KEY="generate_any_secure_string_here"

# Ollama (Primary AI Provider - Local)
# Pastikan Ollama sudah terinstall dan model sudah di-pull
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="llama3:8b"

# Supabase Configuration
# Ambil dari Project Settings -> API di Dashboard Supabase
NEXT_PUBLIC_SUPABASE_URL="https://your-project-id.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Database Connection String (Direct Connection)
DATABASE_URL="postgresql://postgres:[your-password]@db.your-project-id.supabase.co:5432/postgres"
